# SwiftPM
.build/
.swiftpm/
# Bundled debug .app output (scripts/make-debug-app.sh) — visible in Finder, not committed.
dist/
# Package.resolved is committed to pin the dependency graph (this package ships an executable).

# Xcode
*.xcodeproj
*.xcworkspace
DerivedData/

# macOS
.DS_Store

# Local assistant/runtime state
.claude/

# Local design / handoff docs (working notes, never committed)
.design/

# Local scratch analysis scripts / scratch renders (not part of the package)
scratchpad/

# The breath palette in Assets/breaths (oneShot recordings + manifest.json) is the
# canonical, committed asset set so renders work straight from a clone. Scratch WAV
# renders dropped into the assets dir are still ignored.
Assets/breaths/*.wav

# Local secrets — API keys come from the environment, never committed
.env
*.local
