# SwiftPM
.build/
.swiftpm/
# Bundled debug .app output (scripts/make-debug-app.sh) — visible in Finder, not committed.
dist/
# Package.resolved is committed to pin the dependency graph (this package ships an executable).

# Xcode
*.xcodeproj
*.xcworkspace
DerivedData/

# macOS
.DS_Store

# Local assistant/runtime state
.claude/

# Local design / handoff docs (working notes, never committed)
.design/

# Local scratch analysis scripts / scratch renders (not part of the package)
scratchpad/

# The breath palette in Assets/breaths (recordings + manifest.json + fragment banks) is the
# canonical, committed asset set so renders work straight from a clone — including a bank's
# enrolled take WAVs. Only the *derived* prepared caches are ignored: they are regenerated from
# the committed takes via `breath-bank prepare-caches`. (Scratch renders belong in scratchpad/.)
Assets/breaths/*.prepared.wav

# Local secrets — API keys come from the environment, never committed
.env
*.local
